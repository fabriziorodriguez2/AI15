# --- Integración con el proxy de Gemini (solo servidor) ---
# La API key NUNCA debe exponerse en el navegador.
# No usar el prefijo NEXT_PUBLIC_ para la key.

# Clave para autenticar contra el proxy (Authorization: Bearer <key>)
GEMINI_PROXY_API_KEY=

# URL base del proxy estudiantil de Gemini/Vertex
GEMINI_PROXY_BASE_URL=https://gemini-vertex-student-proxy.vercel.app

# Modelo de texto por defecto
GEMINI_TEXT_MODEL=gemini-2.5-flash
